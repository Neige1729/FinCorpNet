{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FinCorpNet Task A Submission",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "instance_id",
      "year",
      "target",
      "prediction",
      "ranked_predictions",
      "evidence_paths"
    ],
    "properties": {
      "year": {
        "type": "integer",
        "minimum": 1900,
        "maximum": 2100
      },
      "target": {
        "type": "string"
      },
      "prediction": {
        "type": "string"
      },
      "ranked_predictions": {
        "type": "array",
        "minItems": 1,
        "maxItems": 5,
        "items": {
          "type": "string"
        }
      },
      "evidence_paths": {
        "type": "array",
        "maxItems": 5,
        "items": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          }
        }
      },
      "instance_id": {
        "type": "string"
      }
    },
    "additionalProperties": false
  }
}